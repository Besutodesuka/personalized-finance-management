# Copy to .env and edit values

# AI model for chat (pulled automatically on first start)
# CPU-friendly options with tool calling support:
#   qwen2.5:3b       — 2GB RAM, fast, best for CPU (default)
#   llama3.2:3b      — 2GB RAM, Meta tool-calling model
#   qwen2.5:7b       — 5GB RAM, higher quality, slower on CPU
MODEL_NAME=qwen2.5:3b

# Stream the model's reasoning to the chat UI. Only thinking-capable models
# support this; set false if your model errors or shows no thinking.
CHAT_THINK=true

# Ollama model storage dir (defaults to ~/.ollama on host)
# OLLAMA_MODELS_DIR=~/.ollama

# Override Ollama URL (e.g. if running Ollama natively, not in Docker)
# VLLM_URL=http://host.docker.internal:11434

# Frontend API URL (change if backend runs on different host/port)
# NEXT_PUBLIC_API_URL=http://localhost:8000/api
